#pragma once

namespace ps::ipc::internal {

/**
 * @brief Reproducible Photospider project version embedded in photospiderd.
 *
 * @throws Nothing; this immutable character array requires no runtime
 *         initialization.
 * @note Generated by CMake from `project(VERSION)` without timestamps, source
 *       paths, or commit identifiers, and remains valid for the process
 *       lifetime.
 */
inline constexpr char kServiceVersion[] = "@PROJECT_VERSION@";

}  // namespace ps::ipc::internal
