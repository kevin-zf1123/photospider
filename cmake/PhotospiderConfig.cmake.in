@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(Photospider_FOUND TRUE)
set(Photospider_embedded_FOUND TRUE)
set(Photospider_ipc_client_FOUND @PHOTOSPIDER_BUILD_IPC@)
set(Photospider_operation_sdk_FOUND TRUE)
set(Photospider_operation_runtime_FOUND TRUE)
set(Photospider_operation_opencv_FOUND TRUE)
set(Photospider_scheduler_sdk_FOUND TRUE)

set(_Photospider_need_embedded FALSE)
set(_Photospider_need_threads FALSE)
set(_Photospider_need_opencv_core FALSE)
set(_Photospider_component_error "")
if(Photospider_FIND_COMPONENTS)
  foreach(_Photospider_component IN LISTS Photospider_FIND_COMPONENTS)
    if(_Photospider_component STREQUAL "embedded")
      set(_Photospider_need_embedded TRUE)
      set(_Photospider_need_threads TRUE)
    elseif(_Photospider_component STREQUAL "ipc_client")
      set(_Photospider_need_threads TRUE)
      if(NOT Photospider_ipc_client_FOUND AND
         Photospider_FIND_REQUIRED_ipc_client)
        set(_Photospider_component_error
            "Photospider was built without the ipc_client component")
      endif()
    elseif(_Photospider_component STREQUAL "scheduler_sdk")
      # Header-only scheduler contracts require no external package.
    elseif(_Photospider_component STREQUAL "operation_sdk" OR
           _Photospider_component STREQUAL "operation_runtime")
      # Standard-library contracts and image allocation require no package.
    elseif(_Photospider_component STREQUAL "operation_opencv")
      set(_Photospider_need_opencv_core TRUE)
    else()
      set(Photospider_${_Photospider_component}_FOUND FALSE)
      if(Photospider_FIND_REQUIRED_${_Photospider_component})
        set(_Photospider_component_error
            "Unknown Photospider component: ${_Photospider_component}")
      endif()
    endif()
  endforeach()
else()
  set(_Photospider_need_embedded TRUE)
  set(_Photospider_need_threads TRUE)
endif()

if(_Photospider_need_threads)
  find_dependency(Threads)
endif()
if(_Photospider_need_opencv_core)
  find_dependency(OpenCV COMPONENTS core)
endif()
if(_Photospider_need_embedded)
  if(NOT Photospider_FIND_COMPONENTS OR
     Photospider_FIND_REQUIRED_embedded)
    find_dependency(OpenCV COMPONENTS core imgproc imgcodecs videoio)
    find_dependency(yaml-cpp)
  else()
    find_package(OpenCV QUIET COMPONENTS core imgproc imgcodecs videoio)
    find_package(yaml-cpp QUIET)
    if(NOT OpenCV_FOUND OR NOT TARGET yaml-cpp::yaml-cpp)
      set(Photospider_embedded_FOUND FALSE)
    endif()
  endif()

  if(APPLE AND Photospider_embedded_FOUND)
    find_library(PHOTOSPIDER_METAL_FRAMEWORK NAMES Metal)
    find_library(PHOTOSPIDER_FOUNDATION_FRAMEWORK NAMES Foundation)
    if(NOT PHOTOSPIDER_METAL_FRAMEWORK OR NOT PHOTOSPIDER_FOUNDATION_FRAMEWORK)
      set(Photospider_embedded_FOUND FALSE)
      if(NOT Photospider_FIND_COMPONENTS OR
         Photospider_FIND_REQUIRED_embedded)
        set(Photospider_FOUND FALSE)
        set(Photospider_NOT_FOUND_MESSAGE
            "Photospider embedded requires the Metal and Foundation frameworks on Apple platforms")
        return()
      endif()
    endif()
  endif()
endif()

check_required_components(Photospider)
if(NOT Photospider_FOUND)
  if(_Photospider_component_error)
    set(Photospider_NOT_FOUND_MESSAGE "${_Photospider_component_error}")
  endif()
  return()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/PhotospiderTargets.cmake")
