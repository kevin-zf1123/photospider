# ============================
# 1. 默认忽略一切 (Block Everything)
# ============================
**

# ============================
# 2. 根目录配置文件 (Root Configs)
# ============================
# Personal overlay files are intentionally owned by the local
# .git-personal repository, not by the primary GitHub project repo.
# Keep them ignored here; add them to the overlay with:
# git --git-dir=.git-personal --work-tree=. add -f <path>
.git-personal/
AGENTS.md
CLAUDE.md
GEMINI.md
.claude/
.codex/
openspec/
feedback/

# git & github
!.gitignore
!.dockerignore
!.gitattributes
!.gitmodules
!.github/
!.github/workflows/
!.github/workflows/*.yml
.github/skills/
.github/prompts/
.github/copilot-instructions.md

# Project configs
!.clang-format
!CPPLINT.cfg
!CMakeLists.txt
!CONTEXT.md
!cmake/
!cmake/**/
!cmake/*.cmake.in
!cmake/**/*.cmake.in
!Dockerfile.ci
!manual.md
!readme.md
!LICENSE

# CI entrypoints
!ci/
!ci/**/
!ci/scripts/*.sh

# ============================
# 3. 头文件 (Headers)
# ============================
!include/
!include/**/
!include/**/*.hpp
!include/**/*.h

# ============================
# 4. 源代码 (Source Code)
# ============================
# Application source trees
!apps/
!apps/**/
!apps/**/*.cpp
!apps/**/*.hpp
!apps/**/*.h
!apps/**/*.txt

# Core implementation (C++, Obj-C++)
!src/
!src/**/
!src/**/*.cpp
!src/**/*.mm
!src/**/*.hpp
!src/**/*.txt
!src/lib/ipc/service_version.hpp.in

# Repository-owned plugins
!plugins/
!plugins/**/
!plugins/ops/**/*.cpp
!plugins/ops/**/*.hpp
!plugins/ops/**/*.mm
!plugins/schedulers/*_example_plugin.cpp
!plugins/schedulers/sdk_example_scheduler.hpp

# External libraries (FTXUI etc.)
!extern/
!extern/**/
!extern/**/*.cpp
!extern/**/*.hpp
!extern/**/*.h
!extern/**/CMakeLists.txt

# ============================
# 5. 测试与工具 (Tests & Utils)
# ============================
# Unit tests
!tests/
!tests/**/
!tests/**/*.cpp
!tests/**/*.hpp
!tests/**/*.py
tests/results/

# Utilities (Python scripts, YAML configs, Testcases)
!util/
!util/**/
!util/**/*.yaml
!util/**/*.yml
!util/**/*.py
!util/**/*.md
!util/**/*.txt
!util/**/*.json
util/change.txt
util/99-filed/architecture.md

# ============================
# 6. 文档 (Documentation)
# ============================
!docs/
!docs/**/
!docs/**/*.md
!docs/**/*.png
!docs/**/*.jpg
docs/openspec-zh/
docs/openspec-zh/*.md
docs/openspec-zh/**/
docs/openspec-zh/**/*.md
docs/agents/
docs/agents/*.md
docs/agents/**/
docs/agents/**/*.md
# ============================
# 7. 特例 (Exceptions)
# ============================
# 如果有特定的默认 session 配置需要追踪，可以在这里加
# !sessions/default/config.yaml
