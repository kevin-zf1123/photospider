# ============================
# 1. 默认忽略一切 (Block Everything)
# ============================
**

# ============================
# 2. 根目录配置文件 (Root Configs)
# ============================
# git & github
!.gitignore
!.gitattributes
!.gitmodules
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Project configs
!.clang-format
!CPPLINT.cfg
!CMakeLists.txt
!Dockerfile.ci
!manual.md
!readme.md
!LICENSE

# ============================
# 3. 头文件 (Headers)
# ============================
!include/
!include/**/
!include/**/*.hpp
!include/**/*.h

# ============================
# 4. 源代码 (Source Code)
# ============================
# CLI entry points
!cli/
!cli/**/
!cli/**/*.cpp

# Core implementation (C++, Obj-C++)
!src/
!src/**/
!src/**/*.cpp
!src/**/*.mm
!src/**/*.hpp
!src/**/*.txt

# Custom Operations (Plugins)
!custom_ops/
!custom_ops/**/
!custom_ops/**/*.cpp

# External libraries (FTXUI etc.)
!extern/
!extern/**/
!extern/**/*.cpp
!extern/**/*.hpp
!extern/**/*.h
!extern/**/CMakeLists.txt

# ============================
# 5. 测试与工具 (Tests & Utils)
# ============================
# Unit tests
!tests/
!tests/**/
!tests/**/*.cpp

# Utilities (Python scripts, YAML configs, Testcases)
!util/
!util/**/
!util/**/*.yaml
!util/**/*.yml
!util/**/*.py
!util/**/*.md
!util/**/*.txt
!util/**/*.json
util/change.txt

# ============================
# 6. 文档 (Documentation)
# ============================
!docs/
!docs/**/
!docs/**/*.md
!docs/**/*.png
!docs/**/*.jpg

# ============================
# 7. 特例 (Exceptions)
# ============================
# 如果有特定的默认 session 配置需要追踪，可以在这里加
# !sessions/default/config.yaml